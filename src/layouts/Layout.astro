---
import '@fontsource-variable/fraunces';
import '@fontsource/atkinson-hyperlegible/400.css';
import '@fontsource/atkinson-hyperlegible/700.css';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Łowcy Kamieni' } = Astro.props;
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f5efe1" />
    <meta name="description" content="Rodzinna gra terenowa: szukamy kamieni, minerałów i skamieniałości w całej Polsce!" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site">
      <h1><span class="pick">⛏️</span> Łowcy Kamieni</h1>
      <p class="tagline">Terenowy notes odkrywców skarbów Polski</p>
      <svg class="squiggle" viewBox="0 0 130 12" fill="none" aria-hidden="true">
        <path d="M2 8c10-8 18 6 28-2s18 6 28-2 18 6 28-2 18 6 28-2" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
      </svg>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site">
      Zdjęcia okazów: Wikimedia Commons — autorzy i licencje przy każdym okazie. Gra domowa, offline, bez śledzenia. 🪨
    </footer>

    <nav class="bottombar" aria-label="Wynik i nawigacja">
      <div class="bb-score">
        <span class="bb-points"><span data-score-points>0</span> <small>pkt</small></span>
        <span class="bb-found"><span data-score-found>0</span>/<span data-score-total>0</span> okazów</span>
      </div>
      <div class="bb-level">
        <span class="bb-level-name" data-level-name>Żwirek</span>
        <div class="bb-track"><div class="bb-fill" data-level-fill></div></div>
      </div>
      <div class="bb-nav">
        <a href="/" aria-current={path === '/' ? 'page' : undefined}><span class="ico">🪨</span>Łowy</a>
        <a href="/kolekcja" aria-current={path.startsWith('/kolekcja') ? 'page' : undefined}><span class="ico">🏆</span>Kolekcja</a>
      </div>
    </nav>

    <div class="level-toast" data-level-toast role="status"></div>
  </body>
</html>
